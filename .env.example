# DeepSeek API
DEEPSEEK_API_KEY=sua_chave_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Aplicação
APP_NAME=ChurnShield
MOCK_AI=true

# Banco de dados
DATABASE_URL=sqlite:///./data/churnshield.db

# Custos (USD por 1M tokens — ajustar conforme pricing DeepSeek)
COST_PER_MILLION_INPUT_TOKENS=0.14
COST_PER_MILLION_OUTPUT_TOKENS=0.28

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/churnshield.log
